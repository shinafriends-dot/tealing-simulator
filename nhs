<script>
// ── SCENE NAVIGATION ──
const scenes = document.querySelectorAll('.scene');
const tabs = document.querySelectorAll('.story-tab');

function showScene(n) {
  scenes.forEach((s,i) => { s.classList.toggle('active', i===n); });
  tabs.forEach((t,i) => { t.classList.toggle('active', i===n); });
  if(n===1) startCounter();
  else stopCounter();
}

// ── SCENE 1: LIVE COUNTER ──
let counterInterval, sessionStart, curtailmentRate = 400;

function updateScene1() {
  const gen = +document.getElementById('s1-genSlider').value;
  const cap = +document.getElementById('s1-capSlider').value;
  document.getElementById('s1-gen').innerText = gen + ' MW';
  document.getElementById('s1-cap').innerText = cap + ' MW';
  const curtailed = Math.max(0, gen - cap);
  curtailmentRate = curtailed;
  document.getElementById('s1-curtailed').innerText = curtailed + ' MW';
  const hourly = curtailed * 150;
  document.getElementById('s1-hourly').innerText = '£' + hourly.toLocaleString() + '/hr';
  const annual = hourly * 24 * 365;
  document.getElementById('s1-annual').innerText = fmtBig(annual);
}

function startCounter() {
  sessionStart = Date.now();
  counterInterval = setInterval(() => {
    const elapsed = (Date.now() - sessionStart) / 1000;
    const wasted = (curtailmentRate * 150 / 3600) * elapsed;
    document.getElementById('s1-liveCounter').innerText = '£' + wasted.toFixed(2);
  }, 50);
}

function stopCounter() {
  clearInterval(counterInterval);
}

// ── SCENE 2: FLOW MODE ──
let flowMode = 0;

function setFlowMode(m) {
  flowMode = m;
  document.getElementById('flowBtn0').className = m===0 ? 'toggle-btn active-red' : 'toggle-btn';
  document.getElementById('flowBtn1').className = m===1 ? 'toggle-btn active-green' : 'toggle-btn';

  const drop = document.getElementById('dropLine');
  const bRect = document.getElementById('bufferRect');
  const bTitle = document.getElementById('bufferTitle');
  const bSub1 = document.getElementById('bufferSub1');
  const bSub2 = document.getElementById('bufferSub2');
  const wRect = document.getElementById('warningRect');
  const wTxt = document.getElementById('warningTxt');
  const c2 = document.getElementById('flowCable2');

  if (m === 0) {
    drop.style.stroke = '#ff3d5a';
    bRect.setAttribute('stroke','#ff3d5a');
    bTitle.setAttribute('fill','#ff3d5a'); bTitle.textContent = '⚠ WASTED ENERGY';
    bSub1.setAttribute('fill','#ff3d5a'); bSub1.textContent = '400 MW GROUNDED';
    bSub2.setAttribute('fill','#4a6580'); bSub2.textContent = '£60,000/hr constraint payment';
    wRect.setAttribute('fill','#ff3d5a');
    wTxt.setAttribute('fill','white'); wTxt.textContent = 'CURTAILMENT ACTIVE';
    c2.style.stroke = '#ff3d5a';
  } else {
    drop.style.stroke = '#00e5a0';
    bRect.setAttribute('stroke','#00e5a0');
    bTitle.setAttribute('fill','#00e5a0'); bTitle.textContent = '✓ SMART BUFFER ACTIVE';
    bSub1.setAttribute('fill','white'); bSub1.textContent = 'NHS AI INFERENCE RUNNING';
    bSub2.setAttribute('fill','#4a6580'); bSub2.textContent = 'Generating 65°C district heat';
    wRect.setAttribute('fill','#00e5a0');
    wTxt.setAttribute('fill','#040d18'); wTxt.textContent = 'BUFFER ENGAGED';
    c2.style.stroke = '#1e90ff';
  }
}

// ── SCENE 3: RESPONSE DEMO ──
function runResponseDemo() {
  const bar = document.getElementById('responseBar');
  const label = document.getElementById('responseLabel');
  const steps = [
    {pct:6, txt:'Signal received...', ms:150},
    {pct:30, txt:'PLC processing...', ms:200},
    {pct:65, txt:'DC buffer isolating...', ms:250},
    {pct:100, txt:'✓ Load transfer complete — 187ms', ms:400},
  ];
  const tls = [document.getElementById('tl0'),document.getElementById('tl1'),document.getElementById('tl2'),document.getElementById('tl3')];

  // Reset
  bar.style.width = '0%'; label.textContent = '';
  tls.forEach(t => { t.classList.remove('active-step'); t.querySelector('.tl-time').style.color='var(--grey)'; });

  let delay = 0;
  steps.forEach((s,i) => {
    delay += s.ms;
    setTimeout(() => {
      bar.style.width = s.pct + '%';
      label.textContent = s.txt;
      tls[i].classList.add('active-step');
      tls[i].querySelector('.tl-time').style.color = 'var(--green)';
    }, delay);
  });
}

// ── FORMATTERS ──
function fmtBig(n) {
  if(n>=1e9) return '£'+(n/1e9).toFixed(2)+'B';
  if(n>=1e6) return '£'+(n/1e6).toFixed(1)+'M';
  return '£'+n.toLocaleString();
}

// Init
updateScene1();
</script>
